# Census API key — get a free one at https://api.census.gov/data/key_signup.html
# Required — the pipeline will not run without this.
CENSUS_API_KEY=your_census_api_key_here

# Copernicus CDS API — ERA5 warming trends
# Sign up at https://cds.climate.copernicus.eu/ then find your key at your profile page.
# Required for ERA5 enrichment. If missing, ERA5 enrichment is skipped for uncached places.
CDSAPI_KEY=your-cds-api-key-here
CDSAPI_URL=https://cds.climate.copernicus.eu/api

# PostgreSQL connection string
# Railway: copy from your Postgres service → Connect tab. Set this before running migrate_to_postgres.py.
# Local dev: leave unset to use parquet file caches instead.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Railway auto-sets DATABASE_URL and PORT — do not override PORT in Railway's dashboard.
